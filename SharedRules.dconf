[Rule]
# Minimal shared rule layer for the US-focused two-subscription profile.
# Device-specific [General], [Proxy], and [Proxy Group] sections remain local.
#
# Intent:
# - Direct traffic stays direct.
# - Everything else goes to the profile's dynamic US proxy selector.
# - Do not split proxy traffic by app or business unless a real issue requires it.
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/BattleNetCN.list,DIRECT,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/LocalAreaNetwork.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/UnBan.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/GoogleCN.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/Microsoft.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/Apple.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/ChinaDomain.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/ChinaCompanyIp.list,DIRECT,update-interval=86400
RULE-SET,https://raw.githubusercontent.com/Garylauchina/surge-rules/main/ACL4SSR/Clash/Download.list,DIRECT,update-interval=86400

GEOIP,CN,DIRECT
FINAL,🚀 节点选择
